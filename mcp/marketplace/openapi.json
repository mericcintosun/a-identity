{
  "openapi": "3.1.0",
  "info": {
    "title": "A-Identity — Agent Trust Oracle",
    "version": "1.0.0",
    "summary": "The identity & reputation oracle for the agent economy.",
    "description": "Before one AI agent pays another, it calls A-Identity to verify the counterparty. Four pay-per-call x402 tools over a live on-chain engine: ERC-8004 identity + KYA (Know-Your-Agent), a deterministic 0-1000 reputation score computed from real on-chain settlements, and a pre-transaction ALLOW / WARN / DENY risk verdict. Every number is reproducible and every settlement is on-chain. Paid tools use the x402 protocol (USDC): an unpaid request returns HTTP 402 with payment requirements; after payment the request is replayed and served. Also live on OKX.AI as Agent #6271.",
    "contact": { "name": "A-Identity", "url": "https://a-identity.xyz" },
    "license": { "name": "MIT" }
  },
  "servers": [{ "url": "https://a-identity-asp.onrender.com", "description": "A-Identity Trust Oracle (production)" }],
  "tags": [
    { "name": "tools", "description": "Paid pay-per-call tools (x402, USDC)" },
    { "name": "discovery", "description": "Free discovery, proof, and methodology endpoints" }
  ],
  "paths": {
    "/tools/verify_agent": {
      "post": {
        "tags": ["tools"],
        "summary": "Verify an AI agent's identity (ERC-8004 + KYA)",
        "description": "Returns the agent's on-chain ERC-8004 registration and KYA (wallet-control) status. Price: $0.001 (x402, USDC).",
        "x-price": "$0.001",
        "x-payment": "x402",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentIdRequest" } } } },
        "responses": {
          "200": { "description": "Identity + KYA result", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "402": { "$ref": "#/components/responses/PaymentRequired" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/tools/reputation_score": {
      "post": {
        "tags": ["tools"],
        "summary": "On-chain 0-1000 reputation score",
        "description": "A deterministic 0-1000 reputation score computed from real on-chain settlements, KYA, and tenure. Price: $0.002 (x402, USDC).",
        "x-price": "$0.002",
        "x-payment": "x402",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentIdRequest" } } } },
        "responses": {
          "200": { "description": "Reputation result", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "402": { "$ref": "#/components/responses/PaymentRequired" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/tools/risk_check": {
      "post": {
        "tags": ["tools"],
        "summary": "Pre-transaction ALLOW / WARN / DENY risk verdict",
        "description": "A single ALLOW / WARN / DENY decision with reasons for a counterparty, before you pay it. Optionally takes a txContext to size the risk to the payment. Price: $0.005 (x402, USDC).",
        "x-price": "$0.005",
        "x-payment": "x402",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RiskCheckRequest" } } } },
        "responses": {
          "200": { "description": "Risk verdict", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RiskResult" } } } },
          "402": { "$ref": "#/components/responses/PaymentRequired" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/tools/agent_passport": {
      "post": {
        "tags": ["tools"],
        "summary": "Full agent passport (identity + reputation + KYA + risk)",
        "description": "The full passport in one call: ERC-8004 identity, KYA, reputation, and risk. Price: $0.01 (x402, USDC).",
        "x-price": "$0.01",
        "x-payment": "x402",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentIdRequest" } } } },
        "responses": {
          "200": { "description": "Agent passport", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolResult" } } } },
          "402": { "$ref": "#/components/responses/PaymentRequired" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["discovery"],
        "summary": "Liveness + service card (free)",
        "responses": { "200": { "description": "Service card (tools, prices, payment info)", "content": { "application/json": { "schema": { "type": "object" } } } } }
      }
    },
    "/.well-known/agent.json": {
      "get": {
        "tags": ["discovery"],
        "summary": "Inspectable service manifest (free)",
        "responses": { "200": { "description": "The Agent Marketplace service manifest", "content": { "application/json": { "schema": { "type": "object" } } } } }
      }
    },
    "/proof": {
      "get": {
        "tags": ["discovery"],
        "summary": "Public, verifiable proof of real on-chain settlements (free)",
        "responses": { "200": { "description": "Proof (HTML for a browser, JSON for an API caller)" } }
      }
    },
    "/methodology": {
      "get": {
        "tags": ["discovery"],
        "summary": "Deterministic scoring methodology (free)",
        "responses": { "200": { "description": "Methodology", "content": { "application/json": { "schema": { "type": "object" } } } } }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentIdRequest": {
        "type": "object",
        "required": ["agentId"],
        "properties": {
          "agentId": { "type": "string", "description": "Platform id, ERC-8004 token id (e.g. \"#849980\"), or the owner 0x address.", "maxLength": 128, "examples": ["#849980"] }
        }
      },
      "RiskCheckRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/AgentIdRequest" },
          {
            "type": "object",
            "properties": {
              "txContext": {
                "type": "object",
                "description": "Optional context to size the risk to the intended payment.",
                "properties": {
                  "amountUsd": { "type": "number", "description": "The USD amount about to be paid." },
                  "kind": { "type": "string", "description": "The kind of action (e.g. payment, purchase)." }
                }
              }
            }
          }
        ]
      },
      "ToolResult": {
        "type": "object",
        "description": "Tool-specific result. Common fields shown; each tool adds its own.",
        "properties": {
          "tool": { "type": "string" },
          "agentId": { "type": "string" },
          "checkedAt": { "type": "string", "format": "date-time" }
        }
      },
      "RiskResult": {
        "type": "object",
        "properties": {
          "tool": { "type": "string", "const": "risk_check" },
          "agentId": { "type": "string" },
          "decision": { "type": "string", "enum": ["ALLOW", "WARN", "DENY"] },
          "risk": { "type": "string", "enum": ["low", "medium", "high"] },
          "reasons": { "type": "array", "items": { "type": "string" } },
          "checkedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Error": { "type": "object", "properties": { "error": { "type": "string" } } }
    },
    "responses": {
      "PaymentRequired": {
        "description": "x402 Payment Required. The response body carries the payment requirements; pay in USDC and replay the request.",
        "content": { "application/json": { "schema": { "type": "object", "description": "x402 payment requirements (accepts[], network, asset, amount, payTo)." } } }
      },
      "BadRequest": {
        "description": "Missing or invalid agentId.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    }
  }
}
