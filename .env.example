# Copy to .env.local (or set in your host) and adjust per environment.

# Base URL of the deployed Mintlify docs site. In dev this defaults to
# http://localhost:3000 (see .env.development). In production set it to the
# deployed docs domain so every docs link resolves.
VITE_DOCS_URL=https://docs.a-identity.dev

# Base URL of the A-Identity MCP HTTP server.
VITE_MCP_URL=http://localhost:3399

# WalletConnect / Reown project id (free, from cloud.reown.com). Enables the
# "WalletConnect (mobile)" option in the wallet picker. Public value (baked into
# the frontend build). Leave unset to hide WalletConnect. Set the same value in
# the Vercel project's env for production.
# VITE_WALLETCONNECT_PROJECT_ID=

# Enable the real Circle App Kit unified-balance provider (requires a connected
# wallet adapter). Leave unset to use the working mock provider.
# VITE_ARC_APPKIT=1

# Circle developer platform (console.circle.com). With this set, the MCP server's
# /api/circle and get_circle_status perform a real authenticated ping.
# Sandbox keys look like TEST_API_KEY:<id>:<secret>.
# CIRCLE_API_KEY=
# CIRCLE_API_BASE=https://api.circle.com

# Passwordless email sign-in ("magic link") via Resend (resend.com). Backend-only,
# credential-gated: without RESEND_API_KEY the email path cleanly reports "not
# configured" and the UI falls back to wallet / guest. Set these in the Render env.
# RESEND_API_KEY=re_...
# MAGIC_FROM_EMAIL=A-Identity <onboarding@resend.dev>   # verify a domain to email arbitrary addresses (test sender only reaches your own)
# APP_URL=https://a-identity.vercel.app                 # base URL the emailed link points back to
